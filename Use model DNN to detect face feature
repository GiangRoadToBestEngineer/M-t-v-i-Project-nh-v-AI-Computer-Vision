# Import thư viện:
import cv2 
import numpy as np
import os
import dlib
from imutils import face_utils

# Add model vào chương trình:
face_landmarks_model_path = 'C:/Users/NEOVIA/Desktop/Hoc sau CV/shape_predictor_68_face_landmarks.dat'
face_recognition_model_path = 'C:/Users/NEOVIA/Desktop/Hoc sau CV/dlib_face_recognition_resnet_model_v1.dat'
img_path = 'C:/Users/NEOVIA/Desktop/01/face.png'
# Tạo bộ nhận diện khuôn mặt:
face_detector = dlib.get_frontal_face_detector()
# Đọc hình ảnh và phát hiện khuôn mặt:
img = cv2.imread(img_path)
# Nhận diện các khuôn mặt trên màn hình:
faces = face_detector(img)
# Vòng lặp qua từng khuôn mặt:
for face in faces:
    point_a = face.left() , face.top()
    point_b = face.right() , face.bottom()
    # Phát hiện ra các đặc trưng trên khuôn mặt :
    shape_predictor = dlib.shape_predictor(face_landmarks_model_path)
    face_shape = shape_predictor(img,face)
    face_shape_array = face_utils.shape_to_np(face_shape)

    # Tính toán đặc trưng của khuôn mặt:
    shape_descriptor = dlib.face_recognition_model_v1(face_recognition_model_path)
    face_descriptor = shape_descriptor.compute_face_descriptor(img,face_shape)
    #print(face_descriptor)

    # Vẽ hình chữ nhật và các điểm đặc trưng lên hình ảnh:
    cv2.rectangle(img , point_a , point_b,(0,255,0))
    for point in face_shape_array:
        cv2.circle(img,tuple(point),3,(255,255,255),-1)
    
    # Hiển thị ảnh lên màn hình:
    cv2.imshow('Anh ne',img)

    if cv2.waitKey(1) & 0xFF == ord('q'):
        break


cv2.destroyAllWindows()
